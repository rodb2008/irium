# irium-stratum production environment variables
# Live copy on irium-vps: /etc/irium-pool/stratum.env
# Loaded by systemd via EnvironmentFile=. Copy to /etc/irium-pool/stratum.env
# and fill in IRIUM_RPC_TOKEN before starting the service.

# ---------- iriumd RPC ----------
IRIUM_RPC_BASE=http://127.0.0.1:38300
# Shared secret for HTTP auth between stratum and iriumd.
# Generate with: openssl rand -hex 24
IRIUM_RPC_TOKEN=REPLACE_WITH_RANDOM_HEX_TOKEN

# ---------- Stratum listener ----------
STRATUM_BIND=0.0.0.0:3333
STRATUM_METRICS_BIND=127.0.0.1:3334

# ---------- Difficulty ----------
# Difficulty assigned to a new session before vardiff kicks in.
# Matches the vardiff floor below so NiceHash / MRR rentals get a
# usable starting target.
STRATUM_DEFAULT_DIFF=256000
# Extranonce1 size in bytes. Do not change without firmware coordination.
STRATUM_EXTRANONCE1_SIZE=4
# How often (ms) to poll iriumd for a new block template.
TEMPLATE_REFRESH_MS=1000

# ---------- Logging / hash mode ----------
LOG_LEVEL=info
# Endianness of share-hash comparison. "le" is correct for iriumd.
IRIUM_HASH_CMP_MODE=le

# ---------- Miner family / share validation ----------
IRIUM_STRATUM_MINER_FAMILY=asic
# If 1, accept shares even when local validation fails (debug only).
IRIUM_STRATUM_SOFT_ACCEPT_INVALID_SHARES=0
IRIUM_STRATUM_SHARECHECK_SAMPLES=3

# ---------- Vardiff ----------
IRIUM_STRATUM_VARDIFF_ENABLED=1
IRIUM_STRATUM_VARDIFF_MIN_DIFF=256000
# Ceiling raised to 2_000_000 to accommodate NiceHash / MRR rentals
# without share-submission ratelimiting.
IRIUM_STRATUM_VARDIFF_MAX_DIFF=2000000
IRIUM_STRATUM_VARDIFF_TARGET_SHARE_SECS=15
IRIUM_STRATUM_VARDIFF_RETARGET_SECS=30

# ---------- Templates ----------
IRIUM_TEMPLATE_MAX_AGE_SECONDS=60

# ---------- Found-block audit log ----------
# Host-specific path. Must be writable by the irium user.
IRIUM_STRATUM_FOUND_BLOCKS_FILE=/opt/irium-pool/data/found_blocks-strict.jsonl

# ---------- Keepalive ----------
IRIUM_STRATUM_KEEPALIVE_NOTIFY_SECS=60

# ---------- Session limits ----------
IRIUM_STRATUM_MAX_SESSIONS=500
IRIUM_STRATUM_MAX_CONN_PER_IP=5
IRIUM_STRATUM_CONN_WINDOW_SECS=60

# ---------- Header-relay carrier kill-switch ----------
# Set to "off" to strip BTC/LTC/DOGE header-relay carrier outputs from
# coinbase2 for ALL sessions on this listener. Workaround for small-
# buffer ASIC firmware (NerdQAxe++, Bitaxe, ESP-Miner with BM1370)
# whose JSON parser overflows on ~10KB mining.notify bodies. Use as an
# emergency override; per-session auto-detection by user-agent is the
# preferred mechanism.
# STRATUM_CARRIERS=off

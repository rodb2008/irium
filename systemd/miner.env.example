# Irium miner environment settings
# Update IRIUM_HOME to match your install path.
IRIUM_HOME=/home/irium/irium

# Required payout address (base58 P2PKH) or pubkey hash (40-hex)
# IRIUM_MINER_ADDRESS=Q...
# IRIUM_MINER_PKH=40_hex_chars

# Optional RPC endpoint for templates/submit
# IRIUM_NODE_RPC=https://127.0.0.1:38300
# IRIUM_RPC_CA=/etc/irium/tls/irium.crt
# IRIUM_RPC_TOKEN=change-me

# Optional template controls
# IRIUM_GBT_LONGPOLL=1
# IRIUM_GBT_LONGPOLL_SECS=25
# IRIUM_GBT_MAX_TXS=0
# IRIUM_GBT_MIN_FEE=0

# Optional strict RPC behavior
# IRIUM_MINER_STRICT_RPC=1

# Optional solo Stratum server for local/remote ASIC solo mining
# ASICs connect to this miner; this miner gets templates from IRIUM_NODE_RPC
# and submits full valid blocks to /rpc/submit_block.
# IRIUM_SOLO_STRATUM=1
# IRIUM_SOLO_STRATUM_LISTEN=0.0.0.0:3333
# IRIUM_SOLO_STRATUM_DIFFICULTY=1
# IRIUM_SOLO_STRATUM_REFRESH_SECS=10
# IRIUM_SOLO_STRATUM_EXTRANONCE2_SIZE=4

# Optional Stratum pool mining
# IRIUM_STRATUM_URL=stratum+tcp://pool:3333
# IRIUM_STRATUM_USER=user
# IRIUM_STRATUM_PASS=pass

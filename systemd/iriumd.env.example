# Irium node environment settings
# Update IRIUM_HOME and IRIUM_NODE_CONFIG to match your install path.
IRIUM_HOME=/home/irium/irium
IRIUM_NODE_CONFIG=/home/irium/irium/configs/node.json

# Optional HTTP bind override
# IRIUM_NODE_HOST=127.0.0.1
# IRIUM_NODE_PORT=38300

# Optional TLS settings to enable HTTPS
# IRIUM_TLS_CERT=/etc/irium/tls/irium.crt
# IRIUM_TLS_KEY=/etc/irium/tls/irium.key

# Optional RPC auth token (must also be set for miner/wallet clients)
# IRIUM_RPC_TOKEN=change-me

# Optional public IP override for seed nodes
# IRIUM_NODE_PUBLIC_IP=203.0.113.10
# IRIUM_PUBLIC_IP_PROBE_TARGET=1.1.1.1:80

# Optional agent string
# IRIUM_NODE_AGENT=Irium-Node

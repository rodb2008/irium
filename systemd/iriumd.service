[Unit]
Description=Irium Rust Node
After=network-online.target
Wants=network-online.target

[Service]
User=irium
EnvironmentFile=-/etc/irium/iriumd.env
WorkingDirectory=/home/%u/irium
ExecStart=/home/%u/irium/target/release/iriumd
Restart=on-failure
RestartSec=5
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

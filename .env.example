# Irium Docker Configuration
# Copy this file to .env and fill in your values.
# docker-compose.yml reads these variables automatically.

# ─── Network ──────────────────────────────────────────────────────────────────

# Your server's public IP address, announced to peers so they can connect back.
# Required if your node is behind NAT. Leave empty to skip announcement.
IRIUM_NODE_PUBLIC_IP=

# External host port for P2P connections (default: 38291).
# Change this if 38291 is already in use on your host.
IRIUM_P2P_EXTERNAL_PORT=38291

# External host port for the RPC/API endpoint (default: 38300).
# Change this if 38300 is already in use on your host.
IRIUM_RPC_EXTERNAL_PORT=38300

# External host port for the status endpoint (default: 8080).
# The status endpoint serves GET /status with node health and chain tip data.
# Change this if 8080 is already in use on your host.
IRIUM_STATUS_EXTERNAL_PORT=8080

# ─── Security ─────────────────────────────────────────────────────────────────

# Optional shared secret for RPC authentication.
# Set the same value in both iriumd and irium-miner when using token auth.
# Leave empty to run the RPC endpoint without authentication.
IRIUM_RPC_TOKEN=

# ─── Miner ────────────────────────────────────────────────────────────────────

# IRM address to receive block rewards. Required to run irium-miner.
# Generate one with: irium-wallet new-address
# Example: IRIUM_MINER_ADDRESS=IdHMhq9uqKb3Ns4u9mDaRJzfBBSXNyKvkj
IRIUM_MINER_ADDRESS=

# Number of CPU threads the miner uses (default: 2).
# Set to the number of physical cores available on your machine.
IRIUM_MINER_THREADS=2

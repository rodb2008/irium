{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Irium Core",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "org.iriumlabs.core",
      "icon": [
        "icons/128x128.png",
        "icons/256x256.png",
        "icons/512x512.png",
        "icons/icon.png"
      ]
    },
    "windows": [
      {
        "title": "Irium Core",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline';"
    },
    "allowlist": {
      "all": true
    }
  }
}

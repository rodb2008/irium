[Unit]
Description=Irium Rust Node
After=network.target

[Service]
User=irium
WorkingDirectory=/home/irium/irium
Environment=IRIUM_NODE_CONFIG=/home/irium/irium/configs/node.json
Environment=RUST_LOG=info
ExecStart=/home/irium/.cargo/bin/cargo run --release --bin iriumd
Restart=on-failure
RestartSec=5
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
